datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  firstName String
  lastName  String
  role      String   @default("NURSE")
  patientId String?  @unique
  avatarUrl String?
  active    Boolean  @default(true)
  specialty String?
  isAvailable Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assignmentsAsDoctor Assignment[] @relation("DoctorAssignment")
  assignmentsAsNurse  Assignment[] @relation("NurseAssignment")
  notesAuthored       Note[]
  activityLogs        ActivityLog[]
  tasksCreated        Task[]       @relation("TaskCreator")
  tasksAssigned       Task[]       @relation("TaskAssignee")
  messagesSent        DirectMessage[] @relation("DirectMessageSender")
  messagesReceived    DirectMessage[] @relation("DirectMessageRecipient")
  patient             Patient?     @relation("PatientPortalAccount", fields: [patientId], references: [id])
}

model Floor {
  id        String   @id @default(cuid())
  name      String
  number    Int      @unique
  createdAt DateTime @default(now())
  rooms     Room[]
}

model Ward {
  id        String   @id @default(cuid())
  name      String
  code      String   @unique
  createdAt DateTime @default(now())
  rooms     Room[]
}

model Room {
  id        String   @id @default(cuid())
  number    String   @unique
  floorId   String
  wardId    String
  capacity  Int      @default(1)
  status    String   @default("EMPTY")
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  floor    Floor     @relation(fields: [floorId], references: [id])
  ward     Ward      @relation(fields: [wardId], references: [id])
  patients Patient[]
}

model Patient {
  id               String    @id @default(cuid())
  patientCode      String    @unique
  firstName        String
  lastName         String
  dateOfBirth      DateTime
  sex              String
  phoneNumber      String?
  height           Float?
  weight           Float?
  allergies        String?
  emergencyContact String?
  emergencyPhone   String?
  status           String    @default("ADMITTED")
  registrationStatus String  @default("PENDING")
  createdByRole    String    @default("ADMIN")
  admissionSource  String    @default("WALK_IN")
  intakeType       String    @default("NORMAL")
  admissionStatus  String    @default("ACTIVE")
  admissionDate    DateTime  @default(now())
  dischargeDate    DateTime?
  roomId           String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  room          Room?          @relation(fields: [roomId], references: [id])
  medicalRecord MedicalRecord?
  assignments   Assignment[]
  activityLogs  ActivityLog[]
  documents     Document[]
  tasks         Task[]
  scheduleItems PatientScheduleItem[]
  portalAccount User?                 @relation("PatientPortalAccount")
}

model PatientScheduleItem {
  id          String   @id @default(cuid())
  patientId   String
  title       String
  scheduledAt DateTime
  type        String
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  patient Patient @relation(fields: [patientId], references: [id])

  @@index([patientId, scheduledAt])
}

model MedicalRecord {
  id               String   @id @default(cuid())
  patientId        String   @unique
  diagnosisSummary String?
  medicalHistory   String?
  currentPlan      String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  patient Patient @relation(fields: [patientId], references: [id])
  notes   Note[]
}

model Note {
  id              String   @id @default(cuid())
  medicalRecordId String
  authorId        String
  type            String   @default("PROGRESS")
  content         String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  medicalRecord MedicalRecord @relation(fields: [medicalRecordId], references: [id])
  author        User          @relation(fields: [authorId], references: [id])
}

model Assignment {
  id        String   @id @default(cuid())
  patientId String
  doctorId  String
  nurseId   String?
  role      String   @default("PRIMARY")
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  patient Patient @relation(fields: [patientId], references: [id])
  doctor  User    @relation("DoctorAssignment", fields: [doctorId], references: [id])
  nurse   User?   @relation("NurseAssignment", fields: [nurseId], references: [id])
}

model ActivityLog {
  id        String   @id @default(cuid())
  action    String
  userId    String
  patientId String?
  details   String?
  metadata  String?
  createdAt DateTime @default(now())

  user    User     @relation(fields: [userId], references: [id])
  patient Patient? @relation(fields: [patientId], references: [id])
}

model Task {
  id          String   @id @default(cuid())
  title       String
  description String?
  priority    String   @default("NORMAL")
  status      String   @default("PENDING")
  dueDate     DateTime?
  patientId   String?
  createdById String
  assignedToId String
  completedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  patient    Patient?  @relation(fields: [patientId], references: [id])
  createdBy  User      @relation("TaskCreator", fields: [createdById], references: [id])
  assignedTo User      @relation("TaskAssignee", fields: [assignedToId], references: [id])
}

model Document {
  id         String   @id @default(cuid())
  name       String
  type       String
  url        String?
  patientId  String
  uploadedBy String?
  createdAt  DateTime @default(now())

  patient Patient @relation(fields: [patientId], references: [id])
}

model DirectMessage {
  id          String   @id @default(cuid())
  senderId    String
  recipientId String
  content     String
  readAt      DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  sender    User @relation("DirectMessageSender", fields: [senderId], references: [id])
  recipient User @relation("DirectMessageRecipient", fields: [recipientId], references: [id])

  @@index([senderId, recipientId, createdAt])
  @@index([recipientId, senderId, createdAt])
}
