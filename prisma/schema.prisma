datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  firstName String
  lastName  String
  role      String   @default("NURSE")
  patientId String?  @unique
  avatarUrl String?
  active    Boolean  @default(true)
  specialty String?
  isAvailable Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assignmentsAsDoctor Assignment[] @relation("DoctorAssignment")
  assignmentsAsNurse  Assignment[] @relation("NurseAssignment")
  notesAuthored       Note[]
  activityLogs        ActivityLog[]
  tasksCreated        Task[]       @relation("TaskCreator")
  tasksAssigned       Task[]       @relation("TaskAssignee")
  agentRunsTriggered  AgentRun[]   @relation("AgentRunTrigger")
  approvedSuggestions AgentSuggestion[] @relation("SuggestionApprovedBy")
  rejectedSuggestions AgentSuggestion[] @relation("SuggestionRejectedBy")
  agentNotifications  AgentNotification[] @relation("NotificationRecipient")
  messagesSent        DirectMessage[] @relation("DirectMessageSender")
  messagesReceived    DirectMessage[] @relation("DirectMessageRecipient")
  patient             Patient?     @relation("PatientPortalAccount", fields: [patientId], references: [id])
}

model Floor {
  id        String   @id @default(cuid())
  name      String
  number    Int      @unique
  createdAt DateTime @default(now())
  rooms     Room[]
}

model Ward {
  id        String   @id @default(cuid())
  name      String
  code      String   @unique
  createdAt DateTime @default(now())
  rooms     Room[]
}

model Room {
  id        String   @id @default(cuid())
  number    String   @unique
  floorId   String
  wardId    String
  capacity  Int      @default(1)
  status    String   @default("EMPTY")
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  floor    Floor     @relation(fields: [floorId], references: [id])
  ward     Ward      @relation(fields: [wardId], references: [id])
  patients Patient[]
}

model Patient {
  id               String    @id @default(cuid())
  patientCode      String    @unique
  firstName        String
  lastName         String
  dateOfBirth      DateTime
  sex              String
  phoneNumber      String?
  height           Float?
  weight           Float?
  allergies        String?
  emergencyContact String?
  emergencyPhone   String?
  status           String    @default("ADMITTED")
  registrationStatus String  @default("PENDING")
  createdByRole    String    @default("ADMIN")
  admissionSource  String    @default("WALK_IN")
  intakeType       String    @default("NORMAL")
  admissionStatus  String    @default("ACTIVE")
  admissionDate    DateTime  @default(now())
  dischargeDate    DateTime?
  roomId           String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  room          Room?          @relation(fields: [roomId], references: [id])
  medicalRecord MedicalRecord?
  assignments   Assignment[]
  activityLogs  ActivityLog[]
  documents     Document[]
  tasks         Task[]
  agentRuns     AgentRun[]
  agentSuggestions AgentSuggestion[]
  scheduleItems PatientScheduleItem[]
  portalAccount User?                 @relation("PatientPortalAccount")
}

model PatientScheduleItem {
  id          String   @id @default(cuid())
  patientId   String
  title       String
  scheduledAt DateTime
  type        String
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  patient Patient @relation(fields: [patientId], references: [id])

  @@index([patientId, scheduledAt])
}

model MedicalRecord {
  id               String   @id @default(cuid())
  patientId        String   @unique
  diagnosisSummary String?
  medicalHistory   String?
  currentPlan      String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  patient Patient @relation(fields: [patientId], references: [id])
  notes   Note[]
}

model Note {
  id              String   @id @default(cuid())
  medicalRecordId String
  authorId        String
  type            String   @default("PROGRESS")
  content         String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  medicalRecord MedicalRecord @relation(fields: [medicalRecordId], references: [id])
  author        User          @relation(fields: [authorId], references: [id])
}

model Assignment {
  id        String   @id @default(cuid())
  patientId String
  doctorId  String
  nurseId   String?
  role      String   @default("PRIMARY")
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  patient Patient @relation(fields: [patientId], references: [id])
  doctor  User    @relation("DoctorAssignment", fields: [doctorId], references: [id])
  nurse   User?   @relation("NurseAssignment", fields: [nurseId], references: [id])
}

model ActivityLog {
  id        String   @id @default(cuid())
  action    String
  userId    String
  patientId String?
  details   String?
  metadata  String?
  createdAt DateTime @default(now())

  user    User     @relation(fields: [userId], references: [id])
  patient Patient? @relation(fields: [patientId], references: [id])
}

model Task {
  id          String   @id @default(cuid())
  title       String
  description String?
  source      String   @default("MANUAL")
  sourceSuggestionId String? @unique
  confidence  Float?
  reasoning   String?
  priority    String   @default("NORMAL")
  status      String   @default("PENDING")
  dueDate     DateTime?
  patientId   String?
  createdById String
  assignedToId String
  completedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  patient    Patient?  @relation(fields: [patientId], references: [id])
  createdBy  User      @relation("TaskCreator", fields: [createdById], references: [id])
  assignedTo User      @relation("TaskAssignee", fields: [assignedToId], references: [id])
  sourceSuggestion AgentSuggestion? @relation("TaskSourceSuggestion", fields: [sourceSuggestionId], references: [id])
}

model AgentRun {
  id                String   @id @default(cuid())
  workflowType      String
  triggerEntityType String
  triggerEntityId   String
  status            String   @default("PENDING")
  modelName         String?
  promptVersion     String?
  latencyMs         Int?
  tokenInput        Int?
  tokenOutput       Int?
  errorCode         String?
  errorMessage      String?
  inputJson         String?
  triggeredById     String
  patientId         String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  triggeredBy User   @relation("AgentRunTrigger", fields: [triggeredById], references: [id])
  patient     Patient @relation(fields: [patientId], references: [id])
  suggestions AgentSuggestion[]

  @@index([patientId, createdAt])
  @@index([status, createdAt])
}

model AgentSuggestion {
  id              String   @id @default(cuid())
  agentRunId      String
  patientId       String
  targetType      String   @default("TASK")
  payloadJson     String
  confidence      Float?
  status          String   @default("PENDING")
  approvedById    String?
  approvedAt      DateTime?
  rejectedById    String?
  rejectedAt      DateTime?
  rejectionReason String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  agentRun   AgentRun @relation(fields: [agentRunId], references: [id])
  patient    Patient  @relation(fields: [patientId], references: [id])
  approvedBy User?    @relation("SuggestionApprovedBy", fields: [approvedById], references: [id])
  rejectedBy User?    @relation("SuggestionRejectedBy", fields: [rejectedById], references: [id])
  evidences  SuggestionEvidence[]
  appliedTask Task?   @relation("TaskSourceSuggestion")

  @@index([patientId, status, createdAt])
  @@index([agentRunId])
}

model SuggestionEvidence {
  id           String   @id @default(cuid())
  suggestionId String
  sourceType   String
  sourceId     String
  snippet      String
  score        Float?
  createdAt    DateTime @default(now())

  suggestion AgentSuggestion @relation(fields: [suggestionId], references: [id])

  @@index([suggestionId, createdAt])
}

model AgentNotification {
  id                String   @id @default(cuid())
  recipientUserId   String
  type              String
  title             String
  message           String
  relatedEntityType String?
  relatedEntityId   String?
  readAt            DateTime?
  createdAt         DateTime @default(now())

  recipient User @relation("NotificationRecipient", fields: [recipientUserId], references: [id])

  @@index([recipientUserId, readAt, createdAt])
}

model Document {
  id         String   @id @default(cuid())
  name       String
  type       String
  url        String?
  patientId  String
  uploadedBy String?
  createdAt  DateTime @default(now())

  patient Patient @relation(fields: [patientId], references: [id])
}

model DirectMessage {
  id          String   @id @default(cuid())
  senderId    String
  recipientId String
  content     String
  readAt      DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  sender    User @relation("DirectMessageSender", fields: [senderId], references: [id])
  recipient User @relation("DirectMessageRecipient", fields: [recipientId], references: [id])

  @@index([senderId, recipientId, createdAt])
  @@index([recipientId, senderId, createdAt])
}
